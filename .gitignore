# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
.env.local
.env.*.local
frontend/.env.local
youtube_cookies.txt

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# ── Runtime data (large binary files, not source) ────────────────────────────
backend/uploads/
backend/keyframes/
backend/data/
uploads/
keyframes/
data/
*.db
*.db-journal
*.db-shm
*.db-wal

# ── FAISS indexes (regenerated at runtime) ───────────────────────────────────
*.index
*_faiss_meta.json

# ── Docker ───────────────────────────────────────────────────────────────────
*.override.yml

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Samples (large test files) ───────────────────────────────────────────────
samples/*.mp4
samples/*.mkv
samples/*.mov
