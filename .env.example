# ============================================================
# Lumen — AI Video Summarizer  ·  Environment Variables
# cp .env.example .env  then fill in your values
# ============================================================

# ── AI Provider ───────────────────────────────────────────
# "groq" (free, recommended) | "api" (Gemini) | "local" (Ollama)
AI_PROVIDER=groq

# ── Groq — FREE, no credit card needed ───────────────────
# Sign up: https://console.groq.com → Create API Key
GROQ_API_KEY=gsk_your_groq_key_here

# ── Supabase Auth + Database ──────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
# Get from: Supabase Dashboard → Settings → JWT Keys → Legacy JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here
# Get from: Supabase Dashboard → Settings → Database → URI (Session mode, port 5432)
DATABASE_URL=

# ── Google Gemini (only needed if AI_PROVIDER=api) ───────
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI Whisper API (optional) ────────────────────────
OPENAI_API_KEY=
USE_OPENAI_WHISPER=false

# ── Ollama (only needed if AI_PROVIDER=local) ────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_VLM_MODEL=llava:7b

# ── Whisper (local transcription, used by all providers) ─
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Storage ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
KEYFRAMES_DIR=./keyframes
DB_URL=sqlite:///./data/app.db

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────
# Change both values before deploying
ADMIN_SECRET=change-me-before-deploying
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-deploying-32-chars-min

# ── Rate limits (slowapi format) ─────────────────────────
RATELIMIT_UPLOAD=5/minute
RATELIMIT_UPLOAD_HOURLY=30/hour
RATELIMIT_CHAT=20/minute
RATELIMIT_READ=60/minute

# ── AI call budget (0 = unlimited) ───────────────────────
MAX_AI_CALLS_PER_DAY=500
LUMEN_MAX_MSG_LEN=1000

# ── Error tracking — Sentry (leave empty to disable) ─────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Logging ("json" for production, "pretty" for dev) ────
LOG_FORMAT=pretty

# ── Scaling ───────────────────────────────────────────────
WEB_WORKERS=2
WORKER_CONCURRENCY=2

# ── App ───────────────────────────────────────────────────
DEBUG=false
MAX_UPLOAD_SIZE_MB=500
MAX_SCENES=100
FAISS_TOP_K=5
