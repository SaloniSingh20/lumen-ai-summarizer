# ── Backend API URL (set this when frontend and backend are on different domains)
# In dev (Vite proxy): leave empty
# On Vercel: set to your Render backend URL, e.g. https://lumen-ai-backend.onrender.com
VITE_API_URL=

# ── Supabase (required for email/password login) ─────────
# Get from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Leave both empty to use local admin-token login (no Supabase needed)
